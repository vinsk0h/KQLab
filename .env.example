# ═══════════════════════════════════════════════
# KQLab - Environment Configuration
# ═══════════════════════════════════════════════

# Server port
PORT=3000

# Database encryption key (REQUIRED - min 32 chars)
# Generate with: npm run keygen
DB_ENCRYPTION_KEY=

# Session secret (REQUIRED)
# Generate with: npm run keygen
SESSION_SECRET=

# WebAuthn Relying Party config
# For local dev: localhost
# For production/Docker: your domain or server IP (e.g. kqlab.yourdomain.com)
# WebAuthn requires HTTPS for non-localhost — use a reverse proxy (nginx/Caddy) in prod
RP_ID=localhost
RP_NAME=KQLab

# Origin URL (must match your browser URL exactly, including port)
# Docker example: ORIGIN=https://kqlab.yourdomain.com
ORIGIN=http://localhost:3000

# Production mode (enables secure cookies, stricter CSP)
# NODE_ENV=production

# GitHub token (optional) — increases API rate limit from 60 to 5000 req/h
# Scope: public_repo — generate at github.com/settings/tokens
GITHUB_TOKEN=

# VirusTotal API key (optional) — enables IoC enrichment for IPs, hashes, domains, URLs
# Free tier: 4 lookups/min · Get key at virustotal.com/gui/my-apikey
VT_API_KEY=
