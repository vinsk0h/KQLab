{
  "name": "kqlab",
  "version": "1.0.0",
  "description": "Collaborative KQL query manager for SOC teams",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "keygen": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "sync-repos": "node scripts/sync-repos.js",
    "reset-admin": "node scripts/reset-admin.js",
    "docker:prod": "docker compose up -d",
    "docker:dev": "docker compose -f docker/compose.dev.yml up",
    "docker:test": "pwsh scripts/docker-test.ps1",
    "docker:test:dev": "pwsh scripts/docker-test.ps1 -Mode dev",
    "commit": "node dev/commit.js",
    "release": "node dev/release.js",
    "release:patch": "npm version patch --message \"chore(release): v%s\"",
    "release:minor": "npm version minor --message \"chore(release): v%s\"",
    "release:major": "npm version major --message \"chore(release): v%s\"",
    "version": "git add CHANGELOG.md"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "docx": "^9.6.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "js-yaml": "^4.1.1",
    "pdfkit": "^0.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "puppeteer-core": "^25.0.2"
  }
}
